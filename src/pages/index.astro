---
const invitation = {
  title: 'El Ritual',
  subtitle: 'Una noche para celebrar bajo signos antiguos',
  date: 'Viernes 5 de Junio',
  time: '7:00 p.m.',
  place: 'Av. Los Cipreses P-04',
  address: 'Direccion por confirmar',
  contact: 'https://wa.me/51962237918?text=Confirmo%20mi%20asistencia%20al%20ritual',
};

const details = [
  ['Fecha', invitation.date],
  ['Hora', invitation.time],
  ['Lugar', invitation.place],
  ['Código', 'Negro ceremonial'],
];

const rites = [
  'Trae una ofrenda ',
  'La entrada se abre cuando el reloj marque las 7pm.',
  'Confirma tu presencia antes de que la luna cambie.',
];

const riteIcons = ['gift', 'clock', 'suggestion'];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Invitacion Lovecraftiana para celebrar El Ritual." />
    <title>{invitation.title} | Invitacion</title>
  </head>
  <body>
    <main class="invitation-shell">
      <section class="hero" aria-labelledby="event-title">
        <div class="hero__image" aria-hidden="true"></div>
        <div class="hero__veil" aria-hidden="true"></div>
        <div class="sigil" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="hero__content">
          <p class="kicker">Has sido convocado</p>
          <h1 id="event-title">{invitation.title}</h1>
          <p class="subtitle">{invitation.subtitle}</p>

          <div class="hero__actions" aria-label="Acciones de invitacion">
            <a class="button button--primary" href={invitation.contact}>Confirmar asistencia</a>
            <a class="button button--ghost" href="#detalles">Ver detalles</a>
          </div>
        </div>
      </section>

      <section id="detalles" class="ritual-list" aria-labelledby="rites-title">
        <h2 id="rites-title">Antes de cruzar el umbral</h2>
        <div class="rites">
          {
            rites.map((rite, index) => (
              <article class="rite">
                <div class="rite__header">
                  {riteIcons[index] === 'gift' && (
                    <svg class="rite__icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20 12v8.5H4V12" />
                      <path d="M3 8.5h18V12H3z" />
                      <path d="M12 8.5v12" />
                      <path d="M12 8.5H8.25A2.25 2.25 0 1 1 10.5 6.25L12 8.5Z" />
                      <path d="M12 8.5h3.75A2.25 2.25 0 1 0 13.5 6.25L12 8.5Z" />
                    </svg>
                  )}
                  {riteIcons[index] === 'clock' && (
                    <svg class="rite__icon" viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="12" r="8.5" />
                      <path d="M12 7.5V12l3.25 2.25" />
                      <path d="M6.25 3.75 4 6" />
                      <path d="m17.75 3.75 2.25 2.25" />
                    </svg>
                  )}
                  {riteIcons[index] === 'suggestion' && (
                    <svg class="rite__icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M9 18h6" />
                      <path d="M10 21h4" />
                      <path d="M8.5 14.5c-1.1-1-2-2.45-2-4.25a5.5 5.5 0 0 1 11 0c0 1.8-.9 3.25-2 4.25-.75.68-1.25 1.38-1.25 2.25h-4.5c0-.87-.5-1.57-1.25-2.25Z" />
                      <path d="M12 2.75v-1" />
                      <path d="m4.75 5.25-.7-.7" />
                      <path d="m19.25 5.25.7-.7" />
                    </svg>
                  )}
                </div>
                <p>{rite}</p>
              </article>
            ))
          }
        </div>
      </section>
      <section class="manifesto" aria-labelledby="manifesto-title">
        <div>
          <p class="kicker">La ceremonia</p>
          <h2 id="manifesto-title">Ven a celebrar entre velas, niebla y presagios.</h2>
        </div>
        <p>
          No sera una reunion cualquiera. Sera una fiesta de roles, un encuentro de almas bajo el
          manto de la noche, una experiencia para compartir historias, y misterios. Ven vestido para
          impresionar a los antiguos, con atuendos oscuros, accesorios enigmáticos o tu mejor
          disfraz de criatura nocturna. Trae contigo una ofrenda pequena: puede ser una bebida, un
          snack o un secreto compartible. El ritual comenzara cuando el reloj marque las nueve, asi
          que asegúrate de llegar a tiempo para no perderte ningun momento magico. Confirma tu
          presencia antes de que la luna cambie, y prepárate para una noche inolvidable.
        </p>
      </section>

      <section class="summons" aria-label="Confirmacion final">
        <p>{invitation.address}</p>
        <h2>El circulo se cierra pronto.</h2>
        <a class="button button--primary" href={invitation.contact}>Responder al llamado</a>
      </section>
      <section class="details-band" aria-label="Detalles del evento">
        <div class="details-grid">
          {
            details.map(([label, value]) => (
              <article class="detail-card">
                <p>{label}</p>
                <strong>{value}</strong>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --ink: #111d13;
    --deep: #172919;
    --sea: #415d43;
    --sea-bright: #8fb996;
    --bone: #b3cbb9;
    --paper: #b3cbb9;
    --gold: #709775;
    --ember: #415d43;
    --line: rgba(179, 203, 185, 0.22);
    color-scheme: dark;
    font-family: 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, serif;
    background: var(--ink);
    color: var(--bone);
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      radial-gradient(circle at 15% 20%, rgba(143, 185, 150, 0.16), transparent 28rem),
      radial-gradient(circle at 86% 68%, rgba(65, 93, 67, 0.2), transparent 24rem),
      linear-gradient(180deg, #111d13 0%, #172919 42%, #0b120c 100%);
  }

  a {
    color: inherit;
  }

  .invitation-shell {
    overflow: hidden;
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: end;
    padding: clamp(1.25rem, 2vw, 2rem);
    isolation: isolate;
  }

  .hero__image,
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: -3;
  }

  .hero__image {
    background-image: url('/images/ritual-hero.png');
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    filter: saturate(0.9) contrast(1.08) brightness(0.7);
  }

  .hero__veil {
    z-index: -2;
    background:
      linear-gradient(
        90deg,
        rgba(17, 29, 19, 0.94) 0%,
        rgba(17, 29, 19, 0.7) 42%,
        rgba(17, 29, 19, 0.28) 100%
      ),
      linear-gradient(180deg, rgba(17, 29, 19, 0.18) 0%, rgba(17, 29, 19, 0.2) 58%, #111d13 100%);
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(179, 203, 185, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(179, 203, 185, 0.035) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: linear-gradient(180deg, transparent, #000 15%, #000 70%, transparent);
  }

  .hero__content {
    width: min(48rem, 100%);
    padding: min(8vh, 5rem) 0;
  }

  .kicker {
    margin: 0 0 1rem;
    color: var(--sea-bright);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    text-wrap: balance;
  }

  h1 {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(4.2rem, 15vw, 12rem);
    font-weight: 700;
    line-height: 0.78;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.55);
  }

  .subtitle {
    max-width: 37rem;
    margin: 1.35rem 0 0;
    color: var(--paper);
    font-size: clamp(1.2rem, 2.5vw, 2.2rem);
    line-height: 1.22;
  }

  .hero__actions,
  .summons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__actions {
    margin-top: 2rem;
  }

  .button {
    min-height: 3.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 0;
    padding: 0.9rem 1.25rem;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button--primary {
    border-color: rgba(143, 185, 150, 0.7);
    background: var(--sea-bright);
    color: #111d13;
  }

  .button--ghost {
    background: rgba(17, 29, 19, 0.42);
    color: var(--bone);
    backdrop-filter: blur(10px);
  }

  .sigil {
    position: absolute;
    right: clamp(1.5rem, 8vw, 8rem);
    bottom: clamp(3rem, 12vw, 10rem);
    width: clamp(10rem, 28vw, 24rem);
    aspect-ratio: 1;
    border: 1px solid rgba(112, 151, 117, 0.36);
    border-radius: 50%;
    opacity: 0.58;
    mix-blend-mode: screen;
  }

  .sigil span {
    position: absolute;
    inset: 18%;
    border: 1px solid rgba(143, 185, 150, 0.38);
    transform: rotate(calc(var(--turn, 1) * 22deg));
  }

  .sigil span:nth-child(1) {
    --turn: 1;
  }

  .sigil span:nth-child(2) {
    --turn: 3;
    border-color: rgba(112, 151, 117, 0.4);
  }

  .sigil span:nth-child(3) {
    --turn: 5;
    inset: 34%;
    border-radius: 50%;
  }

  .details-band,
  .manifesto,
  .ritual-list,
  .summons {
    padding: clamp(3.5rem, 8vw, 7rem) clamp(1.25rem, 4vw, 4rem);
  }

  .details-grid {
    width: min(72rem, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
    background: rgba(17, 29, 19, 0.5);
  }

  .detail-card {
    min-height: 10rem;
    padding: clamp(1rem, 3vw, 1.6rem);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .detail-card p,
  .summons > p {
    margin: 0 0 0.65rem;
    color: var(--gold);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .detail-card strong {
    display: block;
    color: var(--bone);
    font-size: clamp(1.25rem, 2vw, 1.85rem);
    line-height: 1.08;
  }

  .manifesto {
    width: min(76rem, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  .manifesto h2,
  .ritual-list h2,
  .summons h2 {
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 5.8rem);
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .manifesto > p {
    margin: 0;
    color: var(--paper);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.55;
  }

  .ritual-list {
    background: linear-gradient(180deg, rgba(65, 93, 67, 0.26), rgba(17, 29, 19, 0.78)), #111d13;
  }

  .ritual-list h2,
  .rites {
    width: min(72rem, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  .rites {
    margin-top: clamp(2rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .rite {
    min-height: 15rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    background: rgba(17, 29, 19, 0.9);
  }

  .rite__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .rite span {
    color: var(--sea-bright);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.76rem;
    font-weight: 900;
  }

  .rite__icon {
    width: 3.2rem;
    height: 3.2rem;
    flex: 0 0 auto;
    color: var(--bone);
    stroke: currentColor;
    stroke-width: 1.65;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    filter: drop-shadow(0 0 1.1rem rgba(143, 185, 150, 0.22));
    opacity: 0.92;
  }

  .rite p {
    margin: 3.5rem 0 0;
    color: var(--paper);
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    line-height: 1.35;
  }

  .summons {
    min-height: 70svh;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    position: relative;
  }

  .summons::before {
    content: '';
    position: absolute;
    inset: auto -8rem -18rem auto;
    width: min(48rem, 88vw);
    aspect-ratio: 1;
    border: 1px solid rgba(143, 185, 150, 0.22);
    border-radius: 50%;
    box-shadow:
      0 0 0 4rem rgba(143, 185, 150, 0.035),
      0 0 8rem rgba(143, 185, 150, 0.17);
    pointer-events: none;
  }

  .summons h2 {
    max-width: 10ch;
    margin-bottom: 1rem;
  }

  @media (max-width: 820px) {
    .hero {
      min-height: 88svh;
    }

    .hero__veil {
      background:
        linear-gradient(
          180deg,
          rgba(17, 29, 19, 0.62) 0%,
          rgba(17, 29, 19, 0.48) 42%,
          #111d13 100%
        ),
        linear-gradient(90deg, rgba(17, 29, 19, 0.9), rgba(17, 29, 19, 0.36));
    }

    .sigil {
      right: -3rem;
      bottom: 20vh;
      opacity: 0.36;
    }

    .details-grid,
    .rites,
    .manifesto {
      grid-template-columns: 1fr;
    }

    .detail-card,
    .rite {
      min-height: auto;
    }

    .rite p {
      margin-top: 2.4rem;
    }
  }

  @media (max-width: 520px) {
    .hero {
      padding: 1rem;
    }

    h1 {
      font-size: clamp(3.5rem, 24vw, 6.2rem);
    }

    .hero__actions,
    .button {
      width: 100%;
    }

    .details-band,
    .manifesto,
    .ritual-list,
    .summons {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
