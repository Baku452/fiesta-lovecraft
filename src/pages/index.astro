---
const invitation = {
	title: "El Ritual",
	subtitle: "Una noche para celebrar bajo signos antiguos",
	date: "Sabado 31 de octubre",
	time: "9:00 p.m.",
	place: "La casa junto al mar",
	address: "Direccion por confirmar",
	contact: "https://wa.me/51999999999?text=Confirmo%20mi%20asistencia%20al%20ritual",
};

const details = [
	["Fecha", invitation.date],
	["Hora", invitation.time],
	["Lugar", invitation.place],
	["Codigo", "Negro ceremonial"],
];

const rites = [
	"Trae una ofrenda pequena: bebida, snack o secreto compartible.",
	"La entrada se abre cuando el reloj marque las nueve.",
	"Confirma tu presencia antes de que la luna cambie.",
];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Invitacion Lovecraftiana para celebrar El Ritual."
		/>
		<title>{invitation.title} | Invitacion</title>
	</head>
	<body>
		<main class="invitation-shell">
			<section class="hero" aria-labelledby="event-title">
				<div class="hero__image" aria-hidden="true"></div>
				<div class="hero__veil" aria-hidden="true"></div>
				<div class="sigil" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</div>

				<div class="hero__content">
					<p class="kicker">Has sido convocado</p>
					<h1 id="event-title">{invitation.title}</h1>
					<p class="subtitle">{invitation.subtitle}</p>

					<div class="hero__actions" aria-label="Acciones de invitacion">
						<a class="button button--primary" href={invitation.contact}>Confirmar asistencia</a>
						<a class="button button--ghost" href="#detalles">Ver detalles</a>
					</div>
				</div>
			</section>

			<section class="details-band" id="detalles" aria-label="Detalles del evento">
				<div class="details-grid">
					{
						details.map(([label, value]) => (
							<article class="detail-card">
								<p>{label}</p>
								<strong>{value}</strong>
							</article>
						))
					}
				</div>
			</section>

			<section class="manifesto" aria-labelledby="manifesto-title">
				<div>
					<p class="kicker">La ceremonia</p>
					<h2 id="manifesto-title">Ven a celebrar entre velas, niebla y presagios.</h2>
				</div>
				<p>
					No sera una reunion cualquiera. Sera una fiesta con musica, sombras bien
					puestas y brindis para quienes no temen mirar demasiado tiempo hacia el
					abismo.
				</p>
			</section>

			<section class="ritual-list" aria-labelledby="rites-title">
				<h2 id="rites-title">Antes de cruzar el umbral</h2>
				<div class="rites">
					{
						rites.map((rite, index) => (
							<article class="rite">
								<span>{String(index + 1).padStart(2, "0")}</span>
								<p>{rite}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="summons" aria-label="Confirmacion final">
				<p>{invitation.address}</p>
				<h2>El circulo se cierra pronto.</h2>
				<a class="button button--primary" href={invitation.contact}>Responder al llamado</a>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--ink: #050706;
		--deep: #09100e;
		--sea: #0f4d45;
		--sea-bright: #43c7ab;
		--bone: #e7dcc6;
		--paper: #c7b98f;
		--gold: #bd9253;
		--ember: #9b5637;
		--line: rgba(231, 220, 198, 0.2);
		color-scheme: dark;
		font-family:
			"Palatino Linotype", Palatino, "Book Antiqua", Georgia, serif;
		background: var(--ink);
		color: var(--bone);
		scroll-behavior: smooth;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-width: 320px;
		background:
			radial-gradient(circle at 15% 20%, rgba(67, 199, 171, 0.14), transparent 28rem),
			radial-gradient(circle at 86% 68%, rgba(155, 86, 55, 0.16), transparent 24rem),
			linear-gradient(180deg, #030504 0%, #0a0e0d 42%, #020303 100%);
	}

	a {
		color: inherit;
	}

	.invitation-shell {
		overflow: hidden;
	}

	.hero {
		position: relative;
		min-height: 92svh;
		display: grid;
		align-items: end;
		padding: clamp(1.25rem, 2vw, 2rem);
		isolation: isolate;
	}

	.hero__image,
	.hero__veil {
		position: absolute;
		inset: 0;
		z-index: -3;
	}

	.hero__image {
		background-image: url("/images/ritual-hero.png");
		background-size: cover;
		background-position: center;
		transform: scale(1.02);
		filter: saturate(0.9) contrast(1.08) brightness(0.7);
	}

	.hero__veil {
		z-index: -2;
		background:
			linear-gradient(90deg, rgba(3, 5, 4, 0.92) 0%, rgba(3, 5, 4, 0.64) 42%, rgba(3, 5, 4, 0.2) 100%),
			linear-gradient(180deg, rgba(3, 5, 4, 0.2) 0%, rgba(3, 5, 4, 0.18) 58%, #050706 100%);
	}

	.hero::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(231, 220, 198, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(231, 220, 198, 0.035) 1px, transparent 1px);
		background-size: 4rem 4rem;
		mask-image: linear-gradient(180deg, transparent, #000 15%, #000 70%, transparent);
	}

	.hero__content {
		width: min(48rem, 100%);
		padding: min(8vh, 5rem) 0;
	}

	.kicker {
		margin: 0 0 1rem;
		color: var(--sea-bright);
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2,
	p {
		text-wrap: balance;
	}

	h1 {
		margin: 0;
		max-width: 11ch;
		font-size: clamp(4.2rem, 15vw, 12rem);
		font-weight: 700;
		line-height: 0.78;
		letter-spacing: 0;
		text-transform: uppercase;
		text-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.55);
	}

	.subtitle {
		max-width: 37rem;
		margin: 1.35rem 0 0;
		color: var(--paper);
		font-size: clamp(1.2rem, 2.5vw, 2.2rem);
		line-height: 1.22;
	}

	.hero__actions,
	.summons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.hero__actions {
		margin-top: 2rem;
	}

	.button {
		min-height: 3.2rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--line);
		border-radius: 0;
		padding: 0.9rem 1.25rem;
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.button:hover {
		transform: translateY(-2px);
	}

	.button--primary {
		border-color: rgba(67, 199, 171, 0.6);
		background: var(--sea-bright);
		color: #03110f;
	}

	.button--ghost {
		background: rgba(5, 7, 6, 0.36);
		color: var(--bone);
		backdrop-filter: blur(10px);
	}

	.sigil {
		position: absolute;
		right: clamp(1.5rem, 8vw, 8rem);
		bottom: clamp(3rem, 12vw, 10rem);
		width: clamp(10rem, 28vw, 24rem);
		aspect-ratio: 1;
		border: 1px solid rgba(189, 146, 83, 0.24);
		border-radius: 50%;
		opacity: 0.58;
		mix-blend-mode: screen;
	}

	.sigil span {
		position: absolute;
		inset: 18%;
		border: 1px solid rgba(67, 199, 171, 0.35);
		transform: rotate(calc(var(--turn, 1) * 22deg));
	}

	.sigil span:nth-child(1) {
		--turn: 1;
	}

	.sigil span:nth-child(2) {
		--turn: 3;
		border-color: rgba(189, 146, 83, 0.32);
	}

	.sigil span:nth-child(3) {
		--turn: 5;
		inset: 34%;
		border-radius: 50%;
	}

	.details-band,
	.manifesto,
	.ritual-list,
	.summons {
		padding: clamp(3.5rem, 8vw, 7rem) clamp(1.25rem, 4vw, 4rem);
	}

	.details-grid {
		width: min(72rem, 100%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
		background: rgba(5, 7, 6, 0.38);
	}

	.detail-card {
		min-height: 10rem;
		padding: clamp(1rem, 3vw, 1.6rem);
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.detail-card p,
	.summons > p {
		margin: 0 0 0.65rem;
		color: var(--gold);
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.detail-card strong {
		display: block;
		color: var(--bone);
		font-size: clamp(1.25rem, 2vw, 1.85rem);
		line-height: 1.08;
	}

	.manifesto {
		width: min(76rem, 100%);
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
		gap: clamp(2rem, 6vw, 6rem);
		align-items: start;
	}

	.manifesto h2,
	.ritual-list h2,
	.summons h2 {
		margin: 0;
		font-size: clamp(2.5rem, 6vw, 5.8rem);
		line-height: 0.9;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.manifesto > p {
		margin: 0;
		color: var(--paper);
		font-size: clamp(1.1rem, 2vw, 1.5rem);
		line-height: 1.55;
	}

	.ritual-list {
		background:
			linear-gradient(180deg, rgba(15, 77, 69, 0.18), rgba(5, 7, 6, 0.7)),
			#060908;
	}

	.ritual-list h2,
	.rites {
		width: min(72rem, 100%);
		margin-left: auto;
		margin-right: auto;
	}

	.rites {
		margin-top: clamp(2rem, 4vw, 3rem);
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		background: var(--line);
		border: 1px solid var(--line);
	}

	.rite {
		min-height: 15rem;
		padding: clamp(1.25rem, 3vw, 2rem);
		background: rgba(5, 7, 6, 0.88);
	}

	.rite span {
		color: var(--sea-bright);
		font-family: ui-sans-serif, system-ui, sans-serif;
		font-size: 0.76rem;
		font-weight: 900;
	}

	.rite p {
		margin: 4rem 0 0;
		color: var(--paper);
		font-size: clamp(1.1rem, 2vw, 1.45rem);
		line-height: 1.35;
	}

	.summons {
		min-height: 70svh;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		position: relative;
	}

	.summons::before {
		content: "";
		position: absolute;
		inset: auto -8rem -18rem auto;
		width: min(48rem, 88vw);
		aspect-ratio: 1;
		border: 1px solid rgba(67, 199, 171, 0.18);
		border-radius: 50%;
		box-shadow:
			0 0 0 4rem rgba(67, 199, 171, 0.03),
			0 0 8rem rgba(67, 199, 171, 0.16);
		pointer-events: none;
	}

	.summons h2 {
		max-width: 10ch;
		margin-bottom: 1rem;
	}

	@media (max-width: 820px) {
		.hero {
			min-height: 88svh;
		}

		.hero__veil {
			background:
				linear-gradient(180deg, rgba(3, 5, 4, 0.6) 0%, rgba(3, 5, 4, 0.46) 42%, #050706 100%),
				linear-gradient(90deg, rgba(3, 5, 4, 0.88), rgba(3, 5, 4, 0.34));
		}

		.sigil {
			right: -3rem;
			bottom: 20vh;
			opacity: 0.36;
		}

		.details-grid,
		.rites,
		.manifesto {
			grid-template-columns: 1fr;
		}

		.detail-card,
		.rite {
			min-height: auto;
		}

		.rite p {
			margin-top: 2.4rem;
		}
	}

	@media (max-width: 520px) {
		.hero {
			padding: 1rem;
		}

		h1 {
			font-size: clamp(3.5rem, 24vw, 6.2rem);
		}

		.hero__actions,
		.button {
			width: 100%;
		}

		.details-band,
		.manifesto,
		.ritual-list,
		.summons {
			padding-left: 1rem;
			padding-right: 1rem;
		}
	}
</style>
