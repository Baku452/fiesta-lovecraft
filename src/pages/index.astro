---
const invitation = {
  title: 'El Ritual',
  subtitle: 'Una noche para celebrar bajo signos antiguos',
  date: 'Viernes 5 de Junio',
  time: '7:00 p.m.',
  place: 'Av. Los Cipreses P-04',
  address: 'Direccion por confirmar',
  contact: 'https://wa.me/51962237918?text=Confirmo%20mi%20asistencia%20al%20ritual',
};

const details = [
  ['Fecha', invitation.date],
  ['Hora', invitation.time],
  ['Lugar', invitation.place],
  ['Código', 'Negro ceremonial'],
];

const rites = [
  'Trae una ofrenda ',
  'La entrada se abre cuando el reloj marque las 7pm.',
  'Confirma tu presencia antes de que la luna cambie.',
];

const riteIcons = ['gift', 'clock', 'suggestion'];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Invitacion Lovecraftiana para celebrar El Ritual." />
    <title>{invitation.title} | Invitacion</title>
  </head>
  <body>
    <main class="invitation-shell">
      <section class="hero" aria-labelledby="event-title">
        <div class="hero__image" aria-hidden="true"></div>
        <canvas class="fog-canvas fog-canvas--hero" data-fog-canvas aria-hidden="true"></canvas>
        <div class="hero__veil" aria-hidden="true"></div>
        <div class="sigil" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="hero__content">
          <p class="kicker">Has sido convocado</p>
          <h1 id="event-title">{invitation.title}</h1>
          <p class="subtitle">{invitation.subtitle}</p>

          <div class="hero__actions" aria-label="Acciones de invitacion">
            <a class="button button--primary" href={invitation.contact}>Confirmar asistencia</a>
            <a class="button button--ghost" href="#detalles">Ver detalles</a>
          </div>
        </div>
      </section>

      <section id="detalles" class="ritual-list" aria-labelledby="rites-title">
        <canvas class="fog-canvas fog-canvas--ritual" data-fog-canvas aria-hidden="true"></canvas>
        <h2 id="rites-title">Antes de cruzar el umbral</h2>
        <div class="rites">
          {
            rites.map((rite, index) => (
              <article class="rite">
                <div class="rite__header">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  {riteIcons[index] === 'gift' && (
                    <svg class="rite__icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20 12v8.5H4V12" />
                      <path d="M3 8.5h18V12H3z" />
                      <path d="M12 8.5v12" />
                      <path d="M12 8.5H8.25A2.25 2.25 0 1 1 10.5 6.25L12 8.5Z" />
                      <path d="M12 8.5h3.75A2.25 2.25 0 1 0 13.5 6.25L12 8.5Z" />
                    </svg>
                  )}
                  {riteIcons[index] === 'clock' && (
                    <svg class="rite__icon" viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="12" r="8.5" />
                      <path d="M12 7.5V12l3.25 2.25" />
                      <path d="M6.25 3.75 4 6" />
                      <path d="m17.75 3.75 2.25 2.25" />
                    </svg>
                  )}
                  {riteIcons[index] === 'suggestion' && (
                    <svg class="rite__icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M9 18h6" />
                      <path d="M10 21h4" />
                      <path d="M8.5 14.5c-1.1-1-2-2.45-2-4.25a5.5 5.5 0 0 1 11 0c0 1.8-.9 3.25-2 4.25-.75.68-1.25 1.38-1.25 2.25h-4.5c0-.87-.5-1.57-1.25-2.25Z" />
                      <path d="M12 2.75v-1" />
                      <path d="m4.75 5.25-.7-.7" />
                      <path d="m19.25 5.25.7-.7" />
                    </svg>
                  )}
                </div>
                <p>{rite}</p>
              </article>
            ))
          }
        </div>
      </section>
      <section class="manifesto" aria-labelledby="manifesto-title" data-cursor-halo>
        <canvas class="fog-canvas" data-fog-canvas aria-hidden="true"></canvas>
        <span class="cursor-halo" aria-hidden="true"></span>
        <div>
          <p class="kicker">La ceremonia</p>
          <h2 id="manifesto-title">Ven a celebrar entre velas, niebla y presagios.</h2>
        </div>
        <p class="runic-text" data-runic-text tabindex="0">
          <span class="runic-text__measure" aria-hidden="true">
            No será una reunion cualquiera. Sera una fiesta de roles, un encuentro de almas bajo el
            manto de la noche, una experiencia para compartir historias, y misterios. Ven vestido
            para impresionar a los antiguos, con atuendos oscuros, accesorios enigmáticos o tu mejor
            disfraz de criatura nocturna. Trae contigo una ofrenda y snacks para compartir. El
            ritual comenzara cuando el reloj marque las 7pm, asi que asegúrate de llegar a tiempo
            para no perderte ningun momento magico. Confirma tu presencia antes de que la luna
            cambie, y prepárate para una noche inolvidable.
          </span>
          <span class="runic-text__reveal" aria-hidden="true">
            No será una reunion cualquiera. Sera una fiesta de roles, un encuentro de almas bajo el
            manto de la noche, una experiencia para compartir historias, y misterios. Ven vestido
            para impresionar a los antiguos, con atuendos oscuros, accesorios enigmáticos o tu mejor
            disfraz de criatura nocturna. Trae contigo una ofrenda y snacks para compartir. El
            ritual comenzara cuando el reloj marque las 7pm, asi que asegúrate de llegar a tiempo
            para no perderte ningun momento magico. Confirma tu presencia antes de que la luna
            cambie, y prepárate para una noche inolvidable.
          </span>
          <span class="runic-text__base" data-runic-base>
            No será una reunion cualquiera. Sera una fiesta de roles, un encuentro de almas bajo el
            manto de la noche, una experiencia para compartir historias, y misterios. Ven vestido
            para impresionar a los antiguos, con atuendos oscuros, accesorios enigmáticos o tu mejor
            disfraz de criatura nocturna. Trae contigo una ofrenda y snacks para compartir. El
            ritual comenzara cuando el reloj marque las 7pm, asi que asegúrate de llegar a tiempo
            para no perderte ningun momento magico. Confirma tu presencia antes de que la luna
            cambie, y prepárate para una noche inolvidable.
          </span>
        </p>
      </section>

      <section class="summons" aria-label="Confirmacion final">
        <canvas class="fog-canvas fog-canvas--summons" data-fog-canvas aria-hidden="true"></canvas>
        <svg class="tentacles" viewBox="0 0 900 520" aria-hidden="true">
          <defs>
            <linearGradient id="tentacleGradient" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#111d13"></stop>
              <stop offset="58%" stop-color="#415d43"></stop>
              <stop offset="100%" stop-color="#8fb996"></stop>
            </linearGradient>
          </defs>
          <path
            class="tentacle tentacle--one"
            d="M720 540C698 460 670 390 616 333C568 282 504 264 468 216C438 176 446 126 488 98C526 73 582 82 610 118C558 107 530 136 546 174C566 222 637 244 690 314C742 382 766 461 790 540Z"
          ></path>
          <path
            class="tentacle tentacle--two"
            d="M820 540C802 470 792 410 812 348C834 281 886 238 886 178C886 133 850 104 810 112C850 72 918 83 944 132C974 188 936 252 900 304C858 365 858 450 890 540Z"
          ></path>
          <path
            class="tentacle tentacle--three"
            d="M604 540C572 486 528 446 474 416C410 381 344 371 306 326C278 293 282 249 314 227C350 202 403 216 426 254C386 238 354 252 352 284C350 318 390 342 446 366C524 398 584 455 650 540Z"
          ></path>
          <path
            class="tentacle tentacle--four"
            d="M870 540C840 500 824 462 828 420C834 368 872 340 890 298C907 258 890 224 854 218C902 198 954 226 960 276C966 329 914 366 902 428C894 470 914 504 936 540Z"
          ></path>
          <g class="suckers suckers--one">
            <ellipse cx="531" cy="152" rx="10" ry="5"></ellipse>
            <ellipse cx="574" cy="226" rx="9" ry="5"></ellipse>
            <ellipse cx="640" cy="304" rx="8" ry="4"></ellipse>
            <ellipse cx="699" cy="400" rx="7" ry="4"></ellipse>
          </g>
          <g class="suckers suckers--two">
            <ellipse cx="858" cy="182" rx="9" ry="5"></ellipse>
            <ellipse cx="881" cy="260" rx="8" ry="4"></ellipse>
            <ellipse cx="854" cy="356" rx="7" ry="4"></ellipse>
          </g>
          <g class="suckers suckers--three">
            <ellipse cx="352" cy="282" rx="8" ry="4"></ellipse>
            <ellipse cx="434" cy="362" rx="7" ry="4"></ellipse>
            <ellipse cx="536" cy="441" rx="6" ry="3"></ellipse>
          </g>
        </svg>
        <p>{invitation.address}</p>
        <h2>El circulo se cierra pronto.</h2>
        <a class="button button--primary" href={invitation.contact}>Responder al llamado</a>
      </section>
      <section class="details-band" aria-label="Detalles del evento">
        <div class="details-grid">
          {
            details.map(([label, value]) => (
              <article class="detail-card">
                <p>{label}</p>
                <strong>{value}</strong>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>

<script>
  import * as THREE from 'three';

  const runeAlphabet = 'ᚠᚢᚦᚨᚱᚲᚷᚹᚺᚾᛁᛃᛇᛈᛉᛊᛏᛒᛖᛗᛚᛜᛞᛟ';
  const runicTexts = document.querySelectorAll('[data-runic-text]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isTouchRunic = window.matchMedia('(hover: none), (pointer: coarse)').matches;

  const isLetter = (char: string) => /[a-záéíóúñü]/i.test(char);
  const randomRune = () => runeAlphabet[Math.floor(Math.random() * runeAlphabet.length)];

  runicTexts.forEach((element) => {
    if (!(element instanceof HTMLElement)) return;

    const textTarget = element.querySelector('[data-runic-base]');
    if (!(textTarget instanceof HTMLElement)) return;

    const original = textTarget.textContent ?? '';
    const letters = original.split('');
    const mutableIndexes = letters
      .map((char, index) => (isLetter(char) ? index : -1))
      .filter((index) => index >= 0);
    let current = [...letters];
    let stable = false;
    let visible = false;
    let lastTick = 0;
    let stableStartedAt = 0;
    let touchRevealTimer: ReturnType<typeof window.setTimeout> | undefined;
    let touchUnsettleTimer: ReturnType<typeof window.setTimeout> | undefined;

    element.dataset.originalText = original;
    element.setAttribute('aria-label', original);

    const seedRunes = (density = 0.36) => {
      current = letters.map((char) =>
        isLetter(char) && Math.random() < density ? randomRune() : char,
      );
      textTarget.textContent = current.join('');
    };

    const stabilize = () => {
      stable = true;
      stableStartedAt = performance.now();
      element.classList.add('is-stable');
    };

    const unsettle = () => {
      stable = false;
      element.classList.remove('is-stable');
    };

    const step = (time) => {
      if (!visible || prefersReducedMotion) {
        textTarget.textContent = original;
        requestAnimationFrame(step);
        return;
      }

      if (time - lastTick > 105) {
        lastTick = time;

        const edits = Math.max(
          isTouchRunic ? 2 : 3,
          Math.ceil(
            mutableIndexes.length *
              (stable ? (isTouchRunic ? 0.14 : 0.08) : isTouchRunic ? 0.018 : 0.035),
          ),
        );
        if (stable) {
          const runeIndexes = mutableIndexes.filter((index) => current[index] !== letters[index]);
          const elapsed = time - stableStartedAt;
          const remainingTicks = Math.max(1, Math.floor((4000 - elapsed) / 105));
          const restoreCount = Math.max(edits, Math.ceil(runeIndexes.length / remainingTicks));

          for (let i = 0; i < restoreCount; i += 1) {
            const index = runeIndexes[Math.floor(Math.random() * runeIndexes.length)];
            if (index !== undefined) current[index] = letters[index];
          }

          if (elapsed >= 4000) current = [...letters];
        } else {
          for (let i = 0; i < edits; i += 1) {
            const index = mutableIndexes[Math.floor(Math.random() * mutableIndexes.length)];
            current[index] = Math.random() > 0.45 ? randomRune() : letters[index];
          }
        }

        textTarget.textContent = current.join('');
      }

      requestAnimationFrame(step);
    };

    if (isTouchRunic) {
      element.classList.add('is-touch-runic');
    }

    element.addEventListener('pointerenter', () => {
      if (!isTouchRunic) stabilize();
    });
    element.addEventListener('focus', stabilize);
    element.addEventListener('pointerleave', () => {
      if (!isTouchRunic) unsettle();
    });
    element.addEventListener('blur', unsettle);
    element.addEventListener('pointerdown', () => {
      if (!isTouchRunic) return;
      window.clearTimeout(touchRevealTimer);
      window.clearTimeout(touchUnsettleTimer);
      unsettle();
      seedRunes(0.32);
      touchRevealTimer = window.setTimeout(stabilize, 180);
      touchUnsettleTimer = window.setTimeout(unsettle, 7800);
    });

    const observer = new IntersectionObserver(
      ([entry]) => {
        visible = entry.isIntersecting;
        if (!visible) {
          window.clearTimeout(touchRevealTimer);
          window.clearTimeout(touchUnsettleTimer);
          stable = false;
          element.classList.remove('is-stable');
          current = [...letters];
          textTarget.textContent = original;
        } else if (isTouchRunic) {
          seedRunes(0.42);
          touchRevealTimer = window.setTimeout(stabilize, 360);
          touchUnsettleTimer = window.setTimeout(unsettle, 8600);
        }
      },
      { threshold: 0.25 },
    );

    observer.observe(element);
    requestAnimationFrame(step);
  });

  document.querySelectorAll('[data-cursor-halo]').forEach((section) => {
    if (!(section instanceof HTMLElement)) return;

    const moveHalo = (event: PointerEvent) => {
      const rect = section.getBoundingClientRect();
      const revealText = section.querySelector('[data-runic-text]');
      section.style.setProperty('--halo-x', `${event.clientX - rect.left}px`);
      section.style.setProperty('--halo-y', `${event.clientY - rect.top}px`);

      if (revealText instanceof HTMLElement) {
        const textRect = revealText.getBoundingClientRect();
        revealText.style.setProperty('--halo-x', `${event.clientX - textRect.left}px`);
        revealText.style.setProperty('--halo-y', `${event.clientY - textRect.top}px`);
      }
    };

    section.addEventListener('pointermove', moveHalo);
    section.addEventListener('pointerdown', (event) => {
      moveHalo(event);
      section.classList.add('has-halo');
      if (isTouchRunic) {
        window.setTimeout(() => section.classList.remove('has-halo'), 5200);
      }
    });

    section.addEventListener('pointerenter', () => {
      section.classList.add('has-halo');
    });

    section.addEventListener('pointerleave', () => {
      if (!isTouchRunic) section.classList.remove('has-halo');
    });

    if (isTouchRunic) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          section.classList.toggle('has-halo', entry.isIntersecting);
        },
        { threshold: 0.36 },
      );

      observer.observe(section);
    }
  });

  document.querySelectorAll('[data-fog-canvas]').forEach((canvas) => {
    if (!(canvas instanceof HTMLCanvasElement) || prefersReducedMotion) return;

    const section = canvas.closest('.hero, .ritual-list, .manifesto, .summons');
    if (!(section instanceof HTMLElement)) return;
    const isHeroFog = section.classList.contains('hero');
    const isRitualFog = section.classList.contains('ritual-list');
    const isSummonsFog = section.classList.contains('summons');

    const renderer = new THREE.WebGLRenderer({
      alpha: true,
      antialias: true,
      canvas,
      powerPreference: 'high-performance',
    });
    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(48, 1, 0.1, 100);
    camera.position.z = isHeroFog ? 20 : isRitualFog ? 18 : isSummonsFog ? 18 : 16;

    const fogGeometry = new THREE.BufferGeometry();
    const fogCount = isHeroFog ? 210 : isRitualFog ? 130 : isSummonsFog ? 120 : 170;
    const positions = new Float32Array(fogCount * 3);
    const sizes = new Float32Array(fogCount);
    const speeds = new Float32Array(fogCount);

    for (let index = 0; index < fogCount; index += 1) {
      positions[index * 3] =
        (Math.random() - 0.5) * (isHeroFog ? 42 : isRitualFog ? 36 : isSummonsFog ? 28 : 34);
      positions[index * 3 + 1] =
        (Math.random() - 0.5) * (isHeroFog ? 22 : isRitualFog ? 18 : isSummonsFog ? 14 : 16);
      positions[index * 3 + 2] = (Math.random() - 0.5) * 10;
      sizes[index] =
        (isHeroFog ? 12 : isRitualFog ? 10 : isSummonsFog ? 10 : 16) +
        Math.random() * (isHeroFog ? 34 : isRitualFog ? 30 : isSummonsFog ? 28 : 44);
      speeds[index] =
        0.16 + Math.random() * (isHeroFog ? 0.55 : isRitualFog ? 0.5 : isSummonsFog ? 0.65 : 0.9);
    }

    fogGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    fogGeometry.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));
    fogGeometry.setAttribute('aSpeed', new THREE.BufferAttribute(speeds, 1));

    const fogMaterial = new THREE.ShaderMaterial({
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      uniforms: {
        uTime: { value: 0 },
        uColor: {
          value: new THREE.Color(
            isHeroFog ? '#709775' : isRitualFog ? '#8fb996' : isSummonsFog ? '#b3cbb9' : '#8fb996',
          ),
        },
      },
      vertexShader: `
        attribute float aSize;
        attribute float aSpeed;
        uniform float uTime;
        varying float vAlpha;

        void main() {
          vec3 transformed = position;
          transformed.x += sin(uTime * aSpeed + position.y * 0.42) * 1.35;
          transformed.y += cos(uTime * aSpeed * 0.7 + position.x * 0.24) * 0.45;

          vec4 mvPosition = modelViewMatrix * vec4(transformed, 1.0);
          gl_PointSize = aSize * (12.0 / -mvPosition.z);
          gl_Position = projectionMatrix * mvPosition;
          vAlpha = 0.12 + (position.z + 5.0) * 0.016;
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        varying float vAlpha;

        void main() {
          vec2 uv = gl_PointCoord - 0.5;
          float dist = length(uv);
          float smoke = smoothstep(0.5, 0.0, dist);
          smoke *= smoothstep(0.5, 0.18, dist);
          gl_FragColor = vec4(uColor, smoke * vAlpha);
        }
      `,
    });

    const fog = new THREE.Points(fogGeometry, fogMaterial);
    scene.add(fog);

    const resize = () => {
      const { width, height } = section.getBoundingClientRect();
      renderer.setSize(width, height, false);
      camera.aspect = width / Math.max(height, 1);
      camera.updateProjectionMatrix();
    };

    const clock = new THREE.Clock();
    let active = true;

    const animate = () => {
      if (!active) return;
      fogMaterial.uniforms.uTime.value = clock.getElapsedTime();
      fog.rotation.z = Math.sin(clock.elapsedTime * 0.12) * 0.025;
      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };

    const observer = new IntersectionObserver(([entry]) => {
      active = entry.isIntersecting;
      if (active) {
        clock.start();
        requestAnimationFrame(animate);
      } else {
        clock.stop();
      }
    });

    window.addEventListener('resize', resize);
    resize();
    observer.observe(section);
    requestAnimationFrame(animate);
  });
</script>

<style>
  :root {
    --ink: #111d13;
    --deep: #172919;
    --sea: #415d43;
    --sea-bright: #8fb996;
    --bone: #b3cbb9;
    --paper: #b3cbb9;
    --gold: #709775;
    --ember: #415d43;
    --line: rgba(179, 203, 185, 0.22);
    color-scheme: dark;
    font-family: 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, serif;
    background: var(--ink);
    color: var(--bone);
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      radial-gradient(circle at 15% 20%, rgba(143, 185, 150, 0.16), transparent 28rem),
      radial-gradient(circle at 86% 68%, rgba(65, 93, 67, 0.2), transparent 24rem),
      linear-gradient(180deg, #111d13 0%, #172919 42%, #0b120c 100%);
  }

  a {
    color: inherit;
  }

  .invitation-shell {
    overflow: hidden;
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: end;
    padding: clamp(1.25rem, 2vw, 2rem);
    isolation: isolate;
    overflow: hidden;
  }

  .hero__image,
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: -3;
  }

  .hero .fog-canvas {
    z-index: 0;
  }

  .hero__image {
    background-image: url('/images/ritual-hero.png');
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    filter: saturate(0.9) contrast(1.08) brightness(0.7);
  }

  .hero__veil {
    z-index: -1;
    background:
      linear-gradient(
        90deg,
        rgba(17, 29, 19, 0.94) 0%,
        rgba(17, 29, 19, 0.7) 42%,
        rgba(17, 29, 19, 0.28) 100%
      ),
      linear-gradient(180deg, rgba(17, 29, 19, 0.18) 0%, rgba(17, 29, 19, 0.2) 58%, #111d13 100%);
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(179, 203, 185, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(179, 203, 185, 0.035) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: linear-gradient(180deg, transparent, #000 15%, #000 70%, transparent);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: min(48rem, 100%);
    padding: min(8vh, 5rem) 0;
  }

  .kicker {
    margin: 0 0 1rem;
    color: var(--sea-bright);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    text-wrap: balance;
  }

  h1 {
    margin: 0;
